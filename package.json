{
  "name": "website",
  "type": "module",
  "module": "index.ts",
  "scripts": {
    "dev": "clear && bun --watch server.ts",
    "start": "bun run server.ts",
    "build": "bun build ./client.ts --outdir ./assets --naming [name].js",
    "check": "echo basic validation passed",
    "html:check": "htmlhint index.html",
    "lint": "oxlint .",
    "ci": "bun run lint && bun run html:check && bun run build"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "htmlhint": "^1.9.2",
    "oxlint": "^1.62.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
